# Configuración de Firebase para la app (Web SDK).
# Cópialo a un archivo .env y completa los valores.
#
# De dónde sacarlos: consola de Firebase → Configuración del proyecto →
# Tus apps → app Web → SDK setup and configuration.
#
# El prefijo EXPO_PUBLIC_ es obligatorio para que Expo los inyecte en el bundle.
# OJO: NO son secretos (quedan visibles en la app compilada); la seguridad la
# dan las reglas de Firestore + la autenticación, no el ocultar estas claves.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
